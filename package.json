{
  "name": "orions-cookbook",
  "version": "0.1.0",
  "private": true,
  "description": "Orion's Cookbook — scout camp meal planning & logistics PWA",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @orions-cookbook/server db:generate",
    "db:migrate": "pnpm --filter @orions-cookbook/server db:migrate",
    "start": "pnpm --filter @orions-cookbook/server start"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
