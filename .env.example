# Shared secret used to sign auth tokens (HMAC). Generate a long random string.
APP_SECRET=change-me-to-a-long-random-secret

# The single shared password every leader uses to log in.
APP_PASSWORD=scouts-honour

# Prisma / SQLite database location. In Docker this points at the mounted volume.
DATABASE_URL=file:./prisma/dev.db

# Currency and unit system are fixed for this deployment.
CURRENCY=RON

# Port the Fastify server listens on.
PORT=3000
